# =============================================================================
# YOLO Auto-Training System - Environment Configuration
# =============================================================================
# This file contains all API keys and configuration for the system.
# Copy this file to .env and fill in your actual values.
#
# 获取API Keys:
# - Deepseek: https://platform.deepseek.com/
# - Roboflow: https://roboflow.com/
# - Kaggle: https://kaggle.com/
# - HuggingFace: https://huggingface.co/
# - Stability AI: https://platform.stability.ai/
# =============================================================================

# =============================================================================
# LLM Configuration (CrewAI Agents) - Deepseek Reasoner
# =============================================================================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# =============================================================================
# Data Discovery APIs
# =============================================================================
# Roboflow - 数据集搜索与下载
# 获取: https://roboflow.com/settings/api
ROBOFLOW_API_KEY=your-roboflow-api-key-here

# Kaggle - 数据集下载
# 获取: https://www.kaggle.com/account -> Create New API Token
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key-here

# HuggingFace - 数据集访问
# 获取: https://huggingface.co/settings/tokens
HF_TOKEN=your-huggingface-token-here

# =============================================================================
# Image Generation (ComfyUI) - Optional
# =============================================================================
# Stability AI - SDXL图像生成
# 获取: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your-stability-api-key-here

# =============================================================================
# Infrastructure Configuration
# =============================================================================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# =============================================================================
# Security
# =============================================================================
# 生产环境请使用复杂的随机字符串
JWT_SECRET_KEY=changeme-use-random-string-in-production

# =============================================================================
# API Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# =============================================================================
# Training Configuration
# =============================================================================
CUDA_VISIBLE_DEVICES=0
OUTPUT_DIR=./runs
DATA_DIR=./data
MODELS_DIR=./models

# =============================================================================
# ComfyUI Configuration
# =============================================================================
COMFYUI_HOST=localhost:8188
COMFYUI_TIMEOUT=300

# =============================================================================
# Test Configuration
# =============================================================================
TEST_MODE=false
BLOCK_NETWORK_IN_TESTS=true
