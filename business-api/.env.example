# Business API Environment Variables
# Location: business-api/.env

# ==================== Server Configuration ====================
BUSINESS_API_PORT=8000

# ==================== Redis ====================
REDIS_URL=redis://localhost:6379/0

# ==================== Training API (GPU Server) ====================
TRAINING_API_URL=http://localhost:8001
TRAINING_API_KEY=your-secure-api-key

# ==================== Security ====================
JWT_SECRET_KEY=change-this-to-random-secret-key

# ==================== Data Source APIs ====================
ROBOFLOW_API_KEY=your-roboflow-key
KAGGLE_USERNAME=your-kaggle-username
KAGGLE_KEY=your-kaggle-key
HUGGINGFACE_TOKEN=your-hf-token

# ==================== LLM for Agents ====================
DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-reasoner

# ==================== CORS ====================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
